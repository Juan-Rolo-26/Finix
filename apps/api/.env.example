DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finix?schema=public"
JWT_SECRET="super-secret-key-change-this"
PORT=3001
API_URL="https://finixarg.com"
FRONTEND_URL="https://finixarg.com"
ADMIN_URL="https://admin.finixarg.com"
APP_URL="https://finixarg.com"
ALLOWED_ORIGINS="https://finixarg.com,https://www.finixarg.com"
RESEND_API_KEY="re_xxx"
EMAIL_FROM="Finix <noreply@finixarg.com>"

# Supabase Auth (required only if you use Supabase for user login)
SUPABASE_URL="https://your-project-ref.supabase.co"
# Only for legacy HS256 projects. Modern Supabase projects verify access tokens via JWKS.
# SUPABASE_JWT_SECRET="legacy-hs256-secret"

# Admin security phase 1
ADMIN_OWNER_EMAIL="owner@finix.com"
# ADMIN_OWNER_USER_ID="uuid-owner-admin"
ADMIN_ALLOWLIST="owner@finix.com"
ADMIN_ACCESS_COOKIE_NAME="finix_admin_at"
ADMIN_REFRESH_COOKIE_NAME="finix_admin_rt"
ADMIN_ACCESS_TTL_SECONDS=900
ADMIN_REFRESH_TTL_SECONDS=604800
ADMIN_PREAUTH_TOKEN_TTL="5m"
ADMIN_SETUP_TOKEN_TTL="10m"
ADMIN_TOTP_ISSUER="Finix Admin"
ADMIN_TOTP_ENCRYPTION_KEY="change-me-long-random-secret"
ADMIN_LOGIN_RATE_WINDOW_MS=600000
ADMIN_LOGIN_RATE_MAX_ATTEMPTS=25
ADMIN_LOGIN_RATE_BLOCK_MS=900000
ADMIN_IP_ALLOWLIST="127.0.0.1/32,::1/128"

# Stripe billing
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
STRIPE_PRO_INVESTOR_PRICE_ID="price_xxx"
STRIPE_PRO_CREATOR_PRICE_ID="price_xxx"

# Local AI (Ollama)
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="mistral:7b"
OLLAMA_TIMEOUT_MS=45000
