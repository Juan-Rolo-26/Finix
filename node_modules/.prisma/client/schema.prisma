generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  username     String    @unique
  password     String? // Managed by Finix for email/password auth; Supabase remains for OAuth
  role         String    @default("USER") // USER, CREATOR, ADMIN
  status       String    @default("ACTIVE") // ACTIVE, BANNED
  shadowbanned Boolean   @default(false)
  lastLogin    DateTime?
  flags        String? // JSON array of warnings

  // Auth additions
  emailVerified            Boolean   @default(false)
  emailVerificationCode    String?
  emailVerificationExpires DateTime?
  loginVerificationCode    String?
  loginVerificationExpires DateTime?
  resetPasswordToken       String?
  resetPasswordExpires     DateTime?
  adminTwoFactorEnabled    Boolean   @default(false)
  adminTotpSecret          String?
  adminTotpTempSecret      String?
  adminTotpTempExpires     DateTime?
  adminLockedUntil         DateTime?
  adminFailedLoginAttempts Int       @default(0)

  // Perfil básico
  bio       String?
  bioLong   String? // Bio extendida para creadores de contenido
  avatarUrl String?
  bannerUrl String? // Banner/portada del perfil

  // Tipo de cuenta
  isInfluencer       Boolean @default(false)
  isVerified         Boolean @default(false)
  accountType        String  @default("BASIC") // BASIC, PRO, CREATOR, ANALYST
  plan               String  @default("FREE") // FREE | PRO
  stripeCustomerId   String? @unique
  subscriptionStatus String  @default("INACTIVE") // INACTIVE | ACTIVE | CANCELED | PAST_DUE | EXPIRED

  // IA limits (for PRO controls)
  aiUsageThisMonth Int       @default(0)
  aiUsageLimit     Int       @default(0)
  lastAiUsageReset DateTime?

  // Información profesional
  title    String? // ej: "Trading Analyst", "Crypto Investor"
  company  String?
  location String?
  website  String?

  // Redes sociales
  linkedinUrl  String?
  twitterUrl   String?
  youtubeUrl   String?
  instagramUrl String?

  // Experiencia y credenciales
  yearsExperience Int?
  specializations String? // JSON array: ["Stocks", "Crypto", "Options"]
  certifications  String? // JSON array de certificaciones

  // Estadísticas públicas
  totalReturn Float? // Retorno total del portfolio (si es público)
  winRate     Float? // Tasa de éxito en trades
  riskScore   Float? // Score de riesgo (1-10)

  // Configuración de privacidad
  isProfilePublic       Boolean @default(true)
  showPortfolio         Boolean @default(false)
  showStats             Boolean @default(false)
  acceptingFollowers    Boolean @default(true)
  showActivity          Boolean @default(true)
  showExactReturns      Boolean @default(true)
  returnsVisibilityMode String  @default("exact") // "exact" | "range"

  // Preferencias de la app
  language            String  @default("es-AR")
  currency            String  @default("USD")
  autoRefreshMarket   Boolean @default(true)
  compactTables       Boolean @default(false)
  showAdvancedMetrics Boolean @default(false)
  theme               String  @default("dark") // "dark" | "light" | "system"
  chartDensity        String  @default("normal") // "basic" | "normal" | "advanced"
  marketNotifications Boolean @default(false)
  timezone            String  @default("America/Argentina/Cordoba")

  // Onboarding
  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(0)

  // Relaciones
  posts        Post[]
  comments     Comment[]
  likes        Like[]
  commentLikes CommentLike[]
  reposts      Repost[]
  saves        Save[]
  postReports  PostReport[]
  followedBy   Follow[]      @relation("following")
  following    Follow[]      @relation("follower")

  portfolios Portfolio[]
  watchlists Watchlist[]

  // Relations: Communities
  createdCommunities   Community[]         @relation("CommunityCreator")
  communityMemberships CommunityMember[]
  communityPosts       CommunityPost[]
  communityResources   CommunityResource[]
  communityPayments    CommunityPayment[]
  subscriptions        Subscription[]
  creatorBalance       CreatorBalance?
  paymentLogs          PaymentLog[]
  creatorApplication   CreatorApplication?

  isCreator Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Messaging
  conversations1          Conversation[]            @relation("ConvParticipant1")
  conversations2          Conversation[]            @relation("ConvParticipant2")
  conversationMemberships ConversationParticipant[]
  createdConversations    Conversation[]            @relation("ConversationCreator")
  sentMessages            DirectMessage[]           @relation("SentMessages")
  stories                 Story[]
  storyViews              StoryView[]

  // Admin relations
  adminLogs      AdminAuditLog[] @relation("AdminActor")
  adminSessions  AdminSession[]
  reportsCreated Report[]        @relation("Reporter")

  // Notifications
  notifications Notification[] @relation("UserNotifications")

  // Hub (Comunidad Finix)
  hubMessages  HubMessage[]  @relation("HubMessages")
  hubPosts     HubPost[]     @relation("HubPosts")
  hubComments  HubComment[]  @relation("HubComments")
  hubEvents    HubEvent[]    @relation("HubEvents")
  hubResources HubResource[] @relation("HubResources")

  @@index([createdAt])
}

model CreatorApplication {
  id           String    @id @default(uuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id])
  bio          String
  experience   String
  education    String
  documentsUrl String?
  status       String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Follow {
  followerId  String
  followingId String
  follower    User   @relation("follower", fields: [followerId], references: [id])
  following   User   @relation("following", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}

model Post {
  id       String @id @default(uuid())
  content  String
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Type: post | image | chart
  type String @default("post")

  visibility String    @default("VISIBLE") // VISIBLE, HIDDEN
  deletedAt  DateTime?

  // Chart-specific
  assetSymbol  String?
  analysisType String? // "technical" | "fundamental"
  riskLevel    String? // "low" | "medium" | "high"

  // Edit window (text only editable for 15 min after creation)
  contentEditedAt DateTime?

  tickers String @default("") // Comma separated

  // Threading / Conversations
  parentId String?
  parent   Post?   @relation("PostThread", fields: [parentId], references: [id])
  replies  Post[]  @relation("PostThread")

  // Quoting functionality
  quotedPostId String?
  quotedPost   Post?   @relation("QuotePost", fields: [quotedPostId], references: [id])
  quotes       Post[]  @relation("QuotePost")

  // Metrics
  viewCount Int @default(0)

  // Relations
  media            PostMedia[]
  likes            Like[]
  comments         Comment[] // Keep legacy comments for now if needed, but the new threading uses 'Post' referencing itself
  reposts          Repost[]
  saves            Save[]
  reports          PostReport[]
  sharedInMessages DirectMessage[] @relation("SharedPostMessages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([authorId])
  @@index([parentId])
}

model PostMedia {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  url       String
  mediaType String // "image"
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Comment {
  // Legacy comment system, eventually you might migrate everything to Post-to-Post replies
  id       String @id @default(uuid())
  content  String
  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  deletedAt DateTime?

  // Nested replies
  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  likes CommentLike[]

  createdAt DateTime @default(now())

  @@index([postId])
}

model CommentLike {
  commentId String
  userId    String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
}

model Like {
  postId String
  userId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([postId, userId])
}

model Repost {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  // We remove 'comment' string. A "quote tweet" will now be a Post that has quotedPostId. 
  // A Repost is ONLY a direct share of the original post without modification.

  @@unique([userId, postId])
}

model Save {
  userId    String
  postId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, postId])
}

model PostReport {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  reason    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model Portfolio {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nombre             String
  descripcion        String?
  objetivo           String?
  monedaBase         String  @default("USD")
  nivelRiesgo        String  @default("medio")
  modoSocial         Boolean @default(false)
  esPrincipal        Boolean @default(false)
  admiteBienesRaices Boolean @default(false)

  // Relations
  holdings     Holding[]
  transactions Transaction[]
  cashAccounts CashAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id       String @id @default(uuid())
  ticker   String @unique
  name     String
  type     String // STOCK, CRYPTO, ETF, BOND
  currency String @default("USD")

  holdings     Holding[]
  transactions Transaction[]
}

model Holding {
  id          String @id @default(uuid())
  portfolioId String
  assetId     String

  quantity    Decimal @default(0)
  averageCost Decimal @default(0) // WAC

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id])

  @@unique([portfolioId, assetId])
}

model Transaction {
  id          String  @id @default(uuid())
  portfolioId String
  assetId     String? // Null for DEPOSIT/WITHDRAW

  type String // BUY, SELL, DIVIDEND, FEE, DEPOSIT, WITHDRAW
  date DateTime @default(now())

  quantity     Decimal @default(0)
  pricePerUnit Decimal @default(0)
  fee          Decimal @default(0)
  total        Decimal @default(0)
  currency     String  @default("USD")

  notes String?

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  asset     Asset?    @relation(fields: [assetId], references: [id])

  createdAt DateTime @default(now())
}

model CashAccount {
  id          String  @id @default(uuid())
  portfolioId String
  currency    String
  balance     Decimal @default(0)

  portfolio Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, currency])
}

model Watchlist {
  id      String @id @default(uuid())
  name    String
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  tickers String

  createdAt DateTime @default(now())
}

// ============================================
// NEWS SYSTEM MODELS
// ============================================

model NewsSource {
  id       String  @id @default(uuid())
  name     String  @unique
  apiType  String // 'rss', 'api', 'scraper'
  country  String // 'AR', 'US', 'GLOBAL'
  language String  @default("es")
  isActive Boolean @default(true)
  priority Int     @default(0) // Higher = more important

  news News[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  color       String? // For UI display
  icon        String? // Icon identifier

  news News[]

  createdAt DateTime @default(now())
}

model News {
  id String @id @default(uuid())

  // Content
  title     String
  titleEs   String? // Spanish translation if original is English
  content   String // Full article content
  contentEs String? // Spanish translation
  summary   String // Short summary
  summaryEs String?

  // Metadata
  url           String  @unique
  urlHash       String  @unique // MD5 hash to prevent duplicates
  imageUrl      String?
  language      String  @default("es") // Original language
  wasTranslated Boolean @default(false)

  // Classification
  categoryId String?
  category   NewsCategory? @relation(fields: [categoryId], references: [id])

  sourceId String
  source   NewsSource @relation(fields: [sourceId], references: [id])

  author String?

  // Analysis
  sentiment      String? // 'positive', 'neutral', 'negative'
  sentimentScore Float? // -1.0 to 1.0
  impactLevel    String? // 'high', 'medium', 'low'

  // Associated companies/tickers
  tickers String @default("") // Comma-separated tickers

  // Engagement
  viewCount Int @default(0)

  // Dates
  publishedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt])
  @@index([categoryId])
  @@index([sourceId])
  @@index([sentiment])
}

model FundamentalData {
  id     String @id @default(uuid())
  ticker String @unique

  // Valuation
  pe            Float?
  forwardPe     Float?
  ps            Float?
  pb            Float?
  evEbitda      Float?
  dividendYield Float?

  // Profitability
  roe             Float?
  roa             Float?
  netMargin       Float?
  operatingMargin Float?
  grossMargin     Float?

  // Growth
  revenueGrowth3Y Float?
  revenueGrowth5Y Float?
  epsGrowth       Float?

  // Solidity
  debtEquity   Float?
  currentRatio Float?
  quickRatio   Float?
  freeCashFlow Float?

  // Risk
  beta        Float?
  volatility  Float?
  maxDrawdown Float?

  // Finix Score
  finixScore   Float?
  scoreDetails String? // JSON string

  // AI Analysis
  aiSummary        String?
  strengths        String // JSON stringified array
  risks            String // JSON stringified array
  sectorComparison String?
  conclusion       String?

  lastUpdated DateTime @default(now())
}

model FundamentalSnapshot {
  id                String    @id @default(uuid())
  cacheKey          String    @unique
  ticker            String
  providerRequested String
  providerUsed      String
  payload           String
  fetchedAt         DateTime  @default(now())
  expiresAt         DateTime
  staleAt           DateTime?
  updatedAt         DateTime  @updatedAt

  @@index([ticker, providerRequested])
  @@index([expiresAt])
}

model ProviderHealth {
  provider       String    @id
  state          String    @default("healthy") // healthy | degraded | open
  failCount      Int       @default(0)
  consecutive429 Int       @default(0)
  lastError      String?
  lastFailureAt  DateTime?
  cooldownUntil  DateTime?
  updatedAt      DateTime  @updatedAt
}

// ============================================
// COMMUNITIES SYSTEM MODELS
// ============================================

model Community {
  id          String @id @default(uuid())
  creatorId   String
  creator     User   @relation("CommunityCreator", fields: [creatorId], references: [id])
  name        String
  description String
  category    String // Actions, Crypto, ETFs, Argentina, USA

  imageUrl  String?
  bannerUrl String?

  isPaid      Boolean @default(false)
  price       Decimal @default(0)
  billingType String  @default("monthly") // monthly | yearly
  maxMembers  Int? // nullable

  members  CommunityMember[]
  posts    CommunityPost[]
  payments CommunityPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resources CommunityResource[]
}

model CommunityResource {
  id          String    @id @default(uuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  title       String
  description String?
  resourceUrl String
  isPublic    Boolean   @default(false)
  authorId    String?
  author      User?     @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CommunityMember {
  id          String    @id @default(uuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  subscriptionStatus   String    @default("ACTIVE") // ACTIVE | CANCELED | EXPIRED | PAST_DUE
  paymentStatus        String?   @default("SUCCEEDED")
  role                 String    @default("MEMBER")
  stripePaymentId      String?
  stripeSubscriptionId String?
  expiresAt            DateTime?

  joinedAt DateTime @default(now())

  @@unique([communityId, userId])
  @@index([userId, subscriptionStatus])
}

model CommunityPost {
  id          String    @id @default(uuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])

  content  String
  mediaUrl String?

  isPublic Boolean @default(false) // Preview functionality

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunityPayment {
  id          String    @id @default(uuid())
  communityId String
  community   Community @relation(fields: [communityId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  creatorId String

  amount           Decimal
  commissionAmount Decimal
  creatorAmount    Decimal
  stripePaymentId  String  @unique
  status           String  @default("SUCCEEDED") // PENDING | SUCCEEDED | FAILED | REFUNDED
  payoutStatus     String  @default("PENDING")
  billingType      String  @default("monthly") // monthly | yearly

  createdAt DateTime @default(now())

  revenueEntry FinixRevenue?

  @@index([communityId, createdAt])
  @@index([userId, createdAt])
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String?   @unique
  stripeCustomerId     String?
  status               String    @default("INACTIVE") // INACTIVE | ACTIVE | CANCELED | PAST_DUE | EXPIRED
  planType             String    @default("PRO") // FREE | PRO
  startDate            DateTime  @default(now())
  endDate              DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  revenues FinixRevenue[]

  @@index([userId, status])
}

model FinixRevenue {
  id             String            @id @default(uuid())
  type           String // PLAN | COMMUNITY
  paymentId      String?           @unique
  payment        CommunityPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  subscriptionId String?
  subscription   Subscription?     @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  communityId String?
  userId      String?
  creatorId   String?
  status      String  @default("COMPLETED")

  totalAmount      Decimal
  commissionAmount Decimal
  creatorAmount    Decimal
  createdAt        DateTime @default(now())

  @@index([type, createdAt])
}

model CreatorBalance {
  id               String   @id @default(uuid())
  creatorId        String   @unique
  creator          User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  availableBalance Decimal  @default(0)
  pendingBalance   Decimal  @default(0)
  updatedAt        DateTime @updatedAt

  payouts Payout[]
}

model Payout {
  id               String         @id @default(uuid())
  creatorBalanceId String
  creatorBalance   CreatorBalance @relation(fields: [creatorBalanceId], references: [id], onDelete: Cascade)
  amount           Decimal
  status           String         @default("PENDING") // PENDING | PROCESSING | PAID | FAILED | CANCELED
  stripePayoutId   String?
  createdAt        DateTime       @default(now())
  processedAt      DateTime?

  @@index([status, createdAt])
}

// ============================================
// MESSAGING SYSTEM MODELS
// ============================================

model Conversation {
  id             String                    @id @default(uuid())
  participant1Id String?
  participant2Id String?
  participant1   User?                     @relation("ConvParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2   User?                     @relation("ConvParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  isGroup        Boolean                   @default(false)
  title          String?
  createdById    String?
  createdBy      User?                     @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  participants   ConversationParticipant[]
  messages       DirectMessage[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@index([createdById])
  @@index([isGroup, updatedAt])
}

model ConversationParticipant {
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?

  @@id([conversationId, userId])
  @@index([userId, joinedAt])
  @@index([conversationId, lastReadAt])
}

model DirectMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  attachmentType String?
  attachmentUrl  String?
  attachmentData String?
  sharedPostId   String?
  sharedPost     Post?        @relation("SharedPostMessages", fields: [sharedPostId], references: [id], onDelete: SetNull)
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([sharedPostId])
}

model Story {
  id         String      @id @default(uuid())
  authorId   String
  author     User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content    String?
  mediaUrl   String?
  background String?
  textColor  String?
  createdAt  DateTime    @default(now())
  expiresAt  DateTime
  views      StoryView[]

  @@index([authorId, createdAt])
  @@index([expiresAt])
}

model StoryView {
  storyId  String
  viewerId String
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewer   User     @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@id([storyId, viewerId])
  @@index([viewerId, viewedAt])
}

model PlatformSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PaymentLog {
  id            String   @id @default(uuid())
  stripeEventId String?  @unique
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  type          String
  status        String
  message       String?
  payload       String?
  createdAt     DateTime @default(now())

  @@index([type, createdAt])
}

// ============================================
// ADMIN REPORTING & LOGGING MODELS
// ============================================

model AdminSession {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId, expiresAt])
  @@index([revokedAt])
}

model Report {
  id             String  @id @default(uuid())
  reporterId     String
  targetType     String // "POST", "USER", "COMMENT"
  targetId       String
  reason         String
  status         String  @default("OPEN") // OPEN, IN_REVIEW, RESOLVED
  resolutionNote String?

  reporter  User     @relation("Reporter", fields: [reporterId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model AdminAuditLog {
  id        String  @id @default(uuid())
  action    String // e.g. "BAN_USER", "HIDE_POST", "ROLE_CHANGE"
  actorId   String
  targetId  String?
  sessionId String?
  ipAddress String?
  userAgent String?
  metadata  String? // JSON string

  actor     User     @relation("AdminActor", fields: [actorId], references: [id])
  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  content   String?
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ============================================
// HUB (COMUNIDAD FINIX) MODELS
// ============================================

model HubChannel {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  icon        String? // emoji
  type        String   @default("CHAT") // CHAT | FEED
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  messages HubMessage[]
  posts    HubPost[]

  @@index([order])
}

model HubMessage {
  id        String     @id @default(uuid())
  channelId String
  channel   HubChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId  String
  author    User       @relation("HubMessages", fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  mediaUrl  String?
  isPinned  Boolean    @default(false)
  createdAt DateTime   @default(now())
  editedAt  DateTime?

  @@index([channelId, createdAt])
  @@index([authorId])
}

model HubPost {
  id        String     @id @default(uuid())
  channelId String
  channel   HubChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  authorId  String
  author    User       @relation("HubPosts", fields: [authorId], references: [id], onDelete: Cascade)
  title     String?
  content   String
  mediaUrl  String?
  isPinned  Boolean    @default(false)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  comments HubComment[]

  @@index([channelId, isPinned, createdAt])
  @@index([authorId])
}

model HubComment {
  id        String   @id @default(uuid())
  postId    String
  post      HubPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("HubComments", fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
  @@index([authorId])
}

model HubEvent {
  id          String    @id @default(uuid())
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  link        String?
  authorId    String
  author      User      @relation("HubEvents", fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([startsAt])
}

model HubResource {
  id           String   @id @default(uuid())
  title        String
  description  String?
  url          String
  mediaType    String   @default("link") // video | audio | pdf | image | article | link | file
  thumbnailUrl String?
  duration     String? // e.g. "1:23:45"
  category     String?
  authorId     String
  author       User     @relation("HubResources", fields: [authorId], references: [id], onDelete: Cascade)
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([category, order])
  @@index([mediaType])
}
